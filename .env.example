# ── LLM API Keys ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
GROQ_API_KEY=gsk_...

# ── GitHub ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=                # optional — for GitHub App webhook verification

# ── Database (Supabase transaction pooler) ────────────────
DATABASE_URL=postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres

# ── Weaviate Cloud ────────────────────────────────────────
WEAVIATE_URL=https://YOURCLUSTER.c0.eu-central-1.aws.weaviate.cloud
WEAVIATE_API_KEY=...

# ── Auth ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-32-byte-hex-secret-here

# ── App Settings ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_TOKENS_PER_TASK=50000
PRIMARY_LLM=gpt-4o
FALLBACK_LLM=groq/llama-3.1-70b-versatile
